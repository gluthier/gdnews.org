<%- include('../partials/header') %>
    <div class="post">
        <div class="post-title">
            <% if (post.url) { %>
                <a href="<%= post.url %>">
                    <%= post.title %>
                </a>
                <% } else { %>
                    <%= post.title %>
                        <% } %>
        </div>
        <div class="post-meta">
            <%= post.score || 0 %> points by <%= post.username %>
                    <%= new Date(post.created_at).toLocaleTimeString([], {hour: '2-digit' , minute:'2-digit'}) %> ago
                        <% if (post.url) { %>
                            <span class="domain">
                                <%= new URL(post.url).hostname.replace('www.', '' ) %>
                            </span>
                            <% } %>
        </div>
        <% if (post.content) { %>
            <div class="post-content">
                <%= post.content %>
            </div>
            <% } %>
    </div>

    <div class="comment-form">
        <form action="/item/<%= post.id %>/comment" method="POST">
            <textarea name="content" rows="4" cols="50" required></textarea><br>
            <button type="submit">add comment</button>
        </form>
    </div>

    <div class="comments">
        <% comments.forEach(comment=> { %>
            <div class="comment">
                <div class="comment-meta">
                    <%= comment.username %>
                        <%= new Date(comment.created_at).toLocaleString() %>
                </div>
                <div class="comment-content">
                    <%= comment.content %>
                </div>
            </div>
            <% }); %>
    </div>
    <%- include('../partials/footer') %>