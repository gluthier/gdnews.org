<%- include('../partials/header') %>
    <div class="posts">
        <div class="post">
            <div class="post-title">
                <% if (post.url) { %>
                    <a href="<%= post.url %>">
                        <%= post.title %>
                    </a>
                    <% } else { %>
                        <%= post.title %>
                            <% } %>
                                <% if (post.url) { %>
                                    <span class="domain">
                                        (<%= new URL(post.url).hostname.replace('www.', '' ) %>)
                                    </span>
                                    <% } %>
            </div>
            <div class="post-meta">
                <%= post.score || 0 %> points by <%= post.username %>
                        <%= new Date(post.created_at).toLocaleTimeString([], {hour: '2-digit' , minute:'2-digit'}) %>
                            ago

            </div>
            <% if (post.content) { %>
                <div class="post-content">
                    <%= post.content %>
                </div>
                <% } %>
        </div>

        <div class="comment-form">
            <form action="/item/<%= post.id %>/comment" method="POST">
                <textarea name="content" rows="4" cols="50" required></textarea><br>
                <button type="submit">add comment</button>
            </form>
        </div>

        <div class="comments">

            <% function renderCommentTree(comment, depth, maxDepth=2) { /* If we are at maxDepth and have children, we
                show the children in a hidden div with a toggle */ %>
                <div class="comment">
                    <div class="comment-meta">
                        <%= comment.username %>
                            <%= new Date(comment.created_at).toLocaleString() %>
                                <button
                                    onclick="toggleChildren('<%= comment.id %>', this, <%= comment.descendant_count || 0 %>)">hide</button>
                                <button onclick="showReply('<%= comment.id %>', this)">reply</button>
                    </div>
                    <div class="comment-content" id="content-<%= comment.id %>">
                        <%= comment.content %>
                    </div>

                    <div id="reply-<%= comment.id %>" style="display: none; margin-top: 10px;">
                        <form action="/item/<%= post.id %>/comment" method="POST">
                            <input type="hidden" name="parent_comment_id" value="<%= comment.id %>">
                            <textarea name="content" rows="2" cols="50" required></textarea><br>
                            <button type="submit">submit reply</button>
                            <button type="button"
                                onclick="document.getElementById('reply-<%= comment.id %>').style.display = 'none'">cancel</button>
                        </form>
                    </div>

                    <div id="children-<%= comment.id %>">
                        <% if (comment.children && comment.children.length> 0) { %>
                            <% if (depth < maxDepth) { %>
                                <% const REPLY_LIMIT=5; let visibleChildren=comment.children; let hiddenChildren=[]; if
                                    (comment.children && comment.children.length> REPLY_LIMIT) {
                                    visibleChildren = comment.children.slice(0, REPLY_LIMIT);
                                    hiddenChildren = comment.children.slice(REPLY_LIMIT);
                                    }
                                    %>
                                    <% visibleChildren.forEach(child=> { renderCommentTree(child, depth + 1, maxDepth);
                                        }); %>

                                        <% if (hiddenChildren.length> 0) { %>
                                            <% const hiddenCount=hiddenChildren.reduce((acc, child)=> acc + 1 +
                                                (child.descendant_count || 0), 0);
                                                %>
                                                <div class="show-more">
                                                    <button
                                                        onclick="this.nextElementSibling.style.display='block'; this.style.display='none'">
                                                        show more (<%= hiddenCount %>)
                                                    </button>
                                                    <div style="display: none;">
                                                        <% hiddenChildren.forEach(child=> { renderCommentTree(child,
                                                            depth + 1, maxDepth); }); %>
                                                    </div>
                                                </div>
                                                <% } %>
                                                    <% } else { %>
                                                        <div class="show-more">
                                                            <button
                                                                onclick="this.nextElementSibling.style.display='block'; this.style.display='none'">
                                                                show more (<%= comment.descendant_count %>)
                                                            </button>
                                                            <div style="display: none;">
                                                                <% comment.children.forEach(child=> {
                                                                    renderCommentTree(child, depth +
                                                                    1, maxDepth + 2);
                                                                    });
                                                                    %>
                                                            </div>
                                                        </div>
                                                        <% } %>
                                                            <% } %>
                    </div>
                </div>
                <% } %>

                    <script>
                        function showReply(commentId, replyBtn) {
                            const replyForm = document.getElementById('reply-' + commentId);
                            if (replyForm) replyForm.style.display = 'block';

                            const contentDiv = document.getElementById('content-' + commentId);
                            const childrenDiv = document.getElementById('children-' + commentId);
                            const hideBtn = replyBtn.previousElementSibling;

                            if (contentDiv && contentDiv.style.display === 'none') {
                                contentDiv.style.display = 'block';
                                if (childrenDiv) childrenDiv.style.display = 'block';
                                if (hideBtn) hideBtn.innerText = 'hide';
                            }
                        }

                        function toggleChildren(commentId, btn, count) {
                            const childrenDiv = document.getElementById('children-' + commentId);
                            const contentDiv = document.getElementById('content-' + commentId);
                            const replyForm = document.getElementById('reply-' + commentId);

                            if (childrenDiv.style.display === 'none') {
                                childrenDiv.style.display = 'block';
                                if (contentDiv) contentDiv.style.display = 'block';
                                btn.innerText = 'hide';
                            } else {
                                childrenDiv.style.display = 'none';
                                if (contentDiv) contentDiv.style.display = 'none';
                                if (replyForm) replyForm.style.display = 'none';
                                if (count > 0) {
                                    btn.innerText = 'show (' + (count + 1) + ')';
                                } else {
                                    btn.innerText = 'show';
                                }
                            }
                        }
                    </script>

                    <% comments.forEach(comment=> { renderCommentTree(comment, 0); }); %>
        </div>
    </div>
    <%- include('../partials/footer') %>