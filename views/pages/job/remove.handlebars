{{> header}}
<div class="content-box">
    <h1>Remove Job Offer</h1>
    <p>You are about to remove your job offer for: <strong>{{job.title}}</strong></p>
    
    {{#if error}}
    <div class="error-message">{{error}}</div>
    {{/if}}

    <div class="removal-options">
        <div class="option-card">
            <h2>1. Successful Hire</h2>
            <p>You found a candidate through GDNews. Congratulations!</p>
            <p><strong>Cost: €100.00</strong></p>
            <form action="/job/item/{{job.id}}/remove/successful" method="POST">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <button type="submit" class="btn-primary">Pay €100 & Mark as Filled</button>
            </form>
        </div>

        <div class="option-divider">OR</div>

        <div class="option-card">
            <h2>2. Unsuccessful Offer</h2>
            <p>You didn't find the right candidate or decided to cancel the offer.</p>
            <p><strong>Cost: Free</strong></p>
            <form action="/job/item/{{job.id}}/remove/unsuccessful" method="POST">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <button type="submit" class="btn-secondary">Remove Offer</button>
            </form>
        </div>
    </div>

    <div class="back-link">
        <a href="/job/item/{{job.id}}">← Back to Job Details</a>
    </div>
</div>

<style>
    .content-box {
        max-width: 800px;
        margin: 20px auto;
        padding: 20px;
        background: #fdfdfd;
        border: 1px solid #ccc;
    }
    .removal-options {
        display: flex;
        gap: 20px;
        margin: 30px 0;
        align-items: stretch;
    }
    .option-card {
        flex: 1;
        padding: 20px;
        border: 1px solid #eee;
        border-radius: 8px;
        background: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    .option-divider {
        display: flex;
        align-items: center;
        font-weight: bold;
        color: #999;
    }
    .btn-primary {
        background: #ff6600;
        color: white;
        border: none;
        padding: 10px 20px;
        cursor: pointer;
        font-weight: bold;
        width: 100%;
    }
    .btn-secondary {
        background: #eee;
        color: #333;
        border: 1px solid #ccc;
        padding: 10px 20px;
        cursor: pointer;
        width: 100%;
    }
    .back-link {
        margin-top: 20px;
    }
    .error-message {
        color: red;
        margin-bottom: 15px;
    }
</style>

{{> footer}}
