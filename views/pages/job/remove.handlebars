{{> header}}
<h1>Remove Job Offer</h1>
<p>You are about to remove your job offer for: <strong>{{job.title}}</strong></p>

{{#if error}}
<div class="error-message">{{error}}</div>
{{/if}}

<div class="removal-options">
    <div class="option-card">
        <h2>Successful Offer</h2>
        <p>You found a candidate through gdnews.</p>
        <p><strong>Cost: €100.00</strong></p>
        <form action="/job/item/{{job.id}}/remove/successful" method="POST">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit" class="primary-button" disabled>remove for €100 (not available yet)</button>
        </form>
    </div>

    <div class="option-divider">OR</div>

    <div class="option-card">
        <h2>Unsuccessful Offer</h2>
        <p>You didn't find a candidate or decided to cancel the offer.</p>
        <p><strong>Cost: Free</strong></p>
        <form action="/job/item/{{job.id}}/remove/unsuccessful" method="POST">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit" class="secondary-button">remove for free</button>
        </form>
    </div>
</div>

<div class="back-link">
    <a href="/job/item/{{job.id}}">← back to job offer</a>
</div>

{{> footer}}
