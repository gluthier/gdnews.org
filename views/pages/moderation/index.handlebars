
{{> header}}

<div class="moderation-container">
    <h1>Moderation</h1>
    
    <div class="tabs">
        <a href="/moderation/comments" class="{{#if (eq moderationType 'comments')}}active{{/if}}">Comments ({{commentCount}})</a>
        <a href="/moderation/users" class="{{#if (eq moderationType 'users')}}active{{/if}}">Users ({{userCount}})</a>
    </div>

    {{#if (eq moderationType 'users')}}
        <table class="moderation-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Type</th>
                    <th>Created At</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {{#each items}}
                <tr>
                    <td>{{this.id}}</td>
                    <td><a href="/user/profile/{{this.username}}">{{this.username}}</a></td>
                    <td>{{this.email}}</td>
                    <td>{{this.user_type}}</td>
                    <td>{{formatDateFull this.created_at}}</td>
                    <td>
                        {{#if this.email_verified}}
                            <span class="status-verified">Verified</span>
                        {{else}}
                            <span class="status-unverified">Unverified</span>
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    {{/if}}

    {{#if (eq moderationType 'comments')}}
        <div class="moderation-comments-list">
            {{#each items}}
            <div class="moderation-comment-item">
                <div class="comment-meta">
                    <span class="comment-author">
                        <a href="/user/profile/{{this.username}}">{{this.username}}</a>
                    </span>
                    <span class="comment-date">{{formatDateFull this.created_at}}</span>
                    <span class="comment-post">
                        on <a href="/post/item/{{this.post_id}}">{{this.post_title}}</a>
                    </span>
                    {{#if this.replied_to_comment_id}}
                         <span class="comment-reply">
                            (replying to comment #{{this.replied_to_comment_id}})
                        </span>
                    {{/if}}
                </div>
                <div class="comment-content">
                    {{formatTextBlockContent this.content}}
                </div>
                <ul class="inline-list comment-actions">
                <div class="comment-actions">
                    <li><a href="/post/item/{{this.post_id}}#comment-{{this.id}}" class="text-button">View Context</a></li>
                    <li><a href="/moderation/comment/{{this.id}}/delete" class="confirm-action" data-csrf="{{@root.csrfToken}}">remove1</a></li>
                    <li>
                        <form action="/moderation/comment/{{this.id}}/delete" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this comment?');">
                            <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                            <button type="submit" class="text-button text-danger">Delete</button>
                        </form>
                    </li>
                    <li>
                        <form action="/moderation/user/{{this.user_id}}/ban" method="POST" style="display:inline;">
                            <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                            <select name="banType" onchange="if(confirm('Ban user ' + '{{this.username}}' + ' as ' + this.value + '?')) this.form.submit(); else this.value='';">
                                <option value="">Ban User...</option>
                                <option value="24hBanned">24 Hours</option>
                                <option value="7dBanned">7 Days</option>
                                <option value="LifeBanned">Lifetime</option>
                            </select>
                        </form>
                    </li>
                </ul>
            </div>
            {{/each}}
        </div>
    {{/if}}
    
    <div class="pagination">
        {{#if prevPage}}
            <a href="/moderation/{{moderationType}}?page={{prevPage}}" class="prev-page">Previous</a>
        {{/if}}
        
        <span class="page-info">Page {{page}} of {{totalPages}}</span>
        
        {{#if nextPage}}
            <a href="/moderation/{{moderationType}}?page={{nextPage}}" class="next-page">Next</a>
        {{/if}}
    </div>
</div>




{{> footer}}
