
{{> header}}

<div class="moderation-container">
    <h1>Moderation</h1>

    <div class="global-actions" style="margin-bottom: 20px; padding: 15px; background: #fff; border: 1px solid #eee; border-radius: 3px;">
        <h3 style="margin-top: 0; font-size: 1.1em; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 10px;">Global Actions</h3>
        <ul class="inline-list" style="display: flex; flex-wrap: wrap; gap: 15px;">
            <li>
                {{#if settings.lock_global}}
                    <button disabled style="opacity: 0.6; cursor: not-allowed;">Lock New Accounts</button>
                    <span style="color: #eb0808; font-size: 0.8em; font-weight: bold;">(GLOBALLY LOCKED)</span>
                {{else}}
                    {{#if settings.lock_signup}}
                        <button class="confirm-global-action" data-key="lock_signup" data-value="false" data-action-text="unlock accounts" data-csrf="{{@root.csrfToken}}">Unlock New Accounts</button>
                        <span style="color: #eb0808; font-size: 0.8em; font-weight: bold;">(LOCKED)</span>
                    {{else}}
                        <button class="confirm-global-action" data-key="lock_signup" data-value="true" data-action-text="lock accounts" data-csrf="{{@root.csrfToken}}">Lock New Accounts</button>
                    {{/if}}
                {{/if}}
            </li>
            <li>
                {{#if settings.lock_global}}
                    <button disabled style="opacity: 0.6; cursor: not-allowed;">Lock New Posts</button>
                    <span style="color: #eb0808; font-size: 0.8em; font-weight: bold;">(GLOBALLY LOCKED)</span>
                {{else}}
                    {{#if settings.lock_posts}}
                        <button class="confirm-global-action" data-key="lock_posts" data-value="false" data-action-text="unlock posts" data-csrf="{{@root.csrfToken}}">Unlock New Posts</button>
                        <span style="color: #eb0808; font-size: 0.8em; font-weight: bold;">(LOCKED)</span>
                    {{else}}
                        <button class="confirm-global-action" data-key="lock_posts" data-value="true" data-action-text="lock posts" data-csrf="{{@root.csrfToken}}">Lock New Posts</button>
                    {{/if}}
                {{/if}}
            </li>
            <li>
                {{#if settings.lock_global}}
                    <button disabled style="opacity: 0.6; cursor: not-allowed;">Lock New Comments</button>
                    <span style="color: #eb0808; font-size: 0.8em; font-weight: bold;">(GLOBALLY LOCKED)</span>
                {{else}}
                    {{#if settings.lock_comments}}
                        <button class="confirm-global-action" data-key="lock_comments" data-value="false" data-action-text="unlock comments" data-csrf="{{@root.csrfToken}}">Unlock New Comments</button>
                        <span style="color: #eb0808; font-size: 0.8em; font-weight: bold;">(LOCKED)</span>
                    {{else}}
                        <button class="confirm-global-action" data-key="lock_comments" data-value="true" data-action-text="lock comments" data-csrf="{{@root.csrfToken}}">Lock New Comments</button>
                    {{/if}}
                {{/if}}
            </li>
            <li style="border-left: 1px solid #eee; padding-left: 15px;">
                {{#if settings.lock_global}}
                    <button class="confirm-global-action" data-key="lock_global" data-value="false" data-action-text="unlock everything" data-csrf="{{@root.csrfToken}}">Unlock Everything</button>
                    <span style="color: #eb0808; font-size: 0.8em; font-weight: bold;">(LOCKED)</span>
                {{else}}
                    <button class="confirm-global-action" data-key="lock_global" data-value="true" data-action-text="lock everything" data-csrf="{{@root.csrfToken}}">Lock Everything</button>
                {{/if}}
            </li>
        </ul>
    </div>
    
    <div class="tabs">
        <a href="/moderation/comments" class="{{#if (eq moderationType 'comments')}}active{{/if}}">Comments ({{commentCount}})</a>
        <a href="/moderation/users" class="{{#if (eq moderationType 'users')}}active{{/if}}">Users ({{userCount}})</a>
    </div>

    {{#if (eq moderationType 'comments')}}
        <div class="moderation-comments-list">
            {{#each items}}
            <div class="moderation-comment-item">
                <div class="comment-meta">
                    <ul class="inline-list">
                        <li>
                            {{> user-profile-link username=this.username user_type=this.user_type}}
                        </li>
                        <li>
                            <a href="/post/item/{{this.post_id}}#comment-{{this.id}}" title="{{formatDateFull this.created_at}}">{{formatDate this.created_at}}</a>
                        </li>
                        <li>
                            <a href="/post/item/{{this.post_id}}">{{this.post_title}}</a>
                        </li>
                        {{#if this.parent_comment_id}}
                        <li>
                             (<a href="#" class="view-parent-comment" data-comment-id="{{this.parent_comment_id}}">replying to comment #{{this.parent_comment_id}}</a>)
                        </li>
                        {{/if}}
                        {{#if (isAdminNotOwner @root.user this)}}
                        <li><a href="/moderation/comment/{{this.id}}/delete" class="confirm-action admin-action" data-csrf="{{@root.csrfToken}}">[remove]</a></li>
                        {{else}}
                        <li><a href="/moderation/comment/{{this.id}}/delete" class="confirm-action" data-csrf="{{@root.csrfToken}}">remove</a></li>
                        {{/if}}
                        {{> moderation-ban this commentUserId=this.user_id}}
                    </ul>
                    <div class="parent-comment-preview" id="parent-preview-{{this.parent_comment_id}}" style="display: none; background: #f9f9f9; padding: 10px; margin: 10px 0; border-left: 3px solid #ccc;">
                        <!-- Content will be loaded here -->
                    </div>
                </div>
                <div class="comment-content">
                    {{formatTextBlockContent this.content}}
                </div>
            </div>
            {{/each}}
        </div>
    {{/if}}

    {{#if (eq moderationType 'users')}}
        <div class="moderation-users-list">
            {{#each items}}
            <div class="moderation-user-item">
                <div class="user-meta">
                    <span class="user-name">
                        {{> user-profile-link username=this.username user_type=this.user_type}}
                    </span>
                    <span class="user-email">
                        {{#if this.email}}
                            {{this.email}}
                            {{#if this.email_verified}}
                                <span class="status-verified" title="Verified">✓</span>
                            {{else}}
                                <span class="status-unverified" title="Unverified">✕</span>
                            {{/if}}
                        {{else}}
                            (no email)
                        {{/if}}
                    </span>
                </div>
                <div class="user-details">
                    <span class="detail-item">Created: {{formatDateFull this.created_at}}</span>
                    {{#if this.last_connection}}
                        <span class="detail-item">Last Connected: {{formatDateFull this.last_connection}}</span>
                    {{else}}
                        <span class="detail-item">Last Connected: Never</span>
                    {{/if}}
                </div>
                
                <ul class="inline-list moderation-actions">
                    {{> moderation-ban this commentUserId=this.id}}
                </ul>
            </div>
            {{/each}}
        </div>
    {{/if}}
    
    <div class="pagination">
        {{#if prevPage}}
            <a href="/moderation/{{moderationType}}?page={{prevPage}}" class="prev-page">Previous</a>
        {{/if}}
        
        <span class="page-info">Page {{page}} of {{totalPages}}</span>
        
        {{#if nextPage}}
            <a href="/moderation/{{moderationType}}?page={{nextPage}}" class="next-page">Next</a>
        {{/if}}
    </div>
</div>

<script src="{{assetUrl '/js/item.js'}}" defer nonce="{{{nonce}}}"></script>
<script src="{{assetUrl '/js/moderation.js'}}" defer nonce="{{{nonce}}}"></script>

<style>
    .moderation-users-list {
        margin-top: 20px;
    }

    .moderation-user-item {
        border-bottom: 1px solid #eee;
        padding: 15px 0;
    }

    .user-meta {
        font-weight: bold;
        margin-bottom: 5px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .user-email {
        font-weight: normal;
        color: #666;
        font-size: 0.9em;
    }

    .status-verified {
        color: green;
        margin-left: 5px;
    }

    .status-unverified {
        color: red;
        margin-left: 5px;
    }

    .user-details {
        font-size: 0.9em;
        color: #828282;
        margin-bottom: 10px;
    }

    .detail-item {
        margin-right: 15px;
        display: inline-block;
    }

    @media (max-width: 600px) {
        .user-meta {
            flex-direction: column;
            align-items: flex-start;
        }
        
        .user-email {
            display: block;
            margin-top: 2px;
        }
        
        .detail-item {
            display: block;
            margin-right: 0;
            margin-bottom: 2px;
        }
    }

    .moderation-comments-list {
        margin-top: 20px;
    }

    .moderation-comment-item {
        border-bottom: 1px solid #eee;
        padding: 15px 0;
    }
</style>

{{> footer}}
