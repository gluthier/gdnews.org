<%- include('../partials/header') %>

    <div class="user-profile">
        <h2>User: <%= profileUser.username %>
        </h2>
        <p>Created: <%= new Date(profileUser.created_at).toLocaleDateString() %>
        </p>

        <% if (typeof user !=='undefined' && user && user.id===profileUser.id) { %>
            <p>Email: <%= profileUser.email || 'Not set' %>
            </p>
            <div class="user-actions">
                <a href="/change-email">change email</a> |
                <a href="/logout">logout</a>
            </div>
            <% } %>

                <h3>Posts</h3>
                <% if (posts.length===0) { %>
                    <p>No posts yet.</p>
                    <% } else { %>
                        <ul class="post-list">
                            <% posts.forEach(post=> { %>
                                <li class="post-item">
                                    <span class="rank"></span>
                                    <div class="post-content">
                                        <div class="post-title">
                                            <% if (post.url) { %>
                                                <a href="<%= post.url %>">
                                                    <%= post.title %>
                                                </a>
                                                <span class="domain">(<%= new URL(post.url).hostname %>)</span>
                                                <% } else { %>
                                                    <a href="/item/<%= post.id %>">
                                                        <%= post.title %>
                                                    </a>
                                                    <% } %>
                                        </div>
                                        <div class="post-meta">
                                            <%= Math.floor((new Date() - new Date(post.created_at)) / (1000 * 60 * 60))
                                                %> hours ago
                                                | <a href="/item/<%= post.id %>">
                                                    <%= post.comment_count %> comments
                                                </a>
                                        </div>
                                    </div>
                                </li>
                                <% }); %>
                        </ul>
                        <% } %>
    </div>

    <%- include('../partials/footer') %>