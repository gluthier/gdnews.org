{{> header}}

<div class="user-profile">
    <h2>User: {{profileUser.username}}
    </h2>
    <p>Created: {{formatDateFull profileUser.created_at}}
    </p>

    {{#if user}}
    {{#if (eq user.id profileUser.id)}}
    <p>Email: {{#if profileUser.email}}{{profileUser.email}}{{else}}Not set{{/if}}
    </p>
    <div class="user-actions">
        <a href="/change-email">change email</a> |
        <a href="/logout">logout</a>
    </div>
    {{/if}}
    {{/if}}

    <h3>Posts</h3>
    {{#if (eq posts.length 0)}}
    <p>No posts yet.</p>
    {{else}}
    <ul class="post-list">
        {{#each posts}}
        <li class="post-item">
            <span class="rank"></span>
            <div class="post-content">
                <div class="post-title">
                    {{#if url}}
                    <a href="{{url}}">
                        {{title}}
                    </a>
                    <span class="domain">({{getHostname url}})</span>
                    {{else}}
                    <a href="/item/{{id}}">
                        {{title}}
                    </a>
                    {{/if}}
                </div>
                <div class="post-meta">
                    {{hoursAgo created_at}} hours ago
                    | <a href="/item/{{id}}">
                        {{comment_count}} comments
                    </a>
                </div>
            </div>
        </li>
        {{/each}}
    </ul>
    {{/if}}
</div>

{{> footer}}