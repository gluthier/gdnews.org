<div class="post">
    <div class="post-title">
        {{#if is_job}}
        <a href="{{#if url}}{{url}}{{else}}{{basePath}}{{id}}{{/if}}" class="job-symbol" title="Job offer"><span class="job-tag">hiring: </span></a>
        {{/if}}
        {{#if is_promoted}}
        <a href="{{#if url}}{{url}}{{else}}{{basePath}}{{id}}{{/if}}" class="promoted-symbol" title="Promoted post">✨ </a>
        {{/if}}
        {{#if url}}
        <a href="{{url}}">{{title}}</a>
        {{else}}
        <a href="{{basePath}}{{id}}">{{title}}</a>
        {{/if}}
        {{#if url}}
        <span class="domain">
            ({{getHostname url}})
        </span>
        {{/if}}
    </div>
    <div class="post-meta">
        <ul class="inline-list">
            {{#unless isDetail}}
            <li>
                <a href="{{basePath}}{{id}}">
                    {{formatCommentCount comment_count}}
                </a>
            </li>
            {{/unless}}

            <li><a href="/user/profile/{{username}}">
            {{#if (eq user_type 'bot')}}<span title="automated account"><span class="bot-emoji">☰</span>{{username}}</span>
            {{else}}{{username}}
            {{/if}}
            </a></li>

            {{#if (eq type 'promoted')}}
                <li><span class="post-date" title="{{formatDateFull promoted_date}}"><strong>
                    scheduled for {{formatDatePromotedPost promoted_date}}
                </strong></span></li>
            {{else if is_promoted}}
                {{#if (isToday promoted_date)}}
                <li><span class="post-date" title="{{formatDateFull promoted_date}}"><strong>
                    scheduled for today
                </strong></span></li>
                {{else}}
                <li><span class="post-date" title="{{formatDateFull promoted_date}}">scheduled {{formatDate promoted_date}}</span></li>
                {{/if}}
            {{else}}
                <li><span class="post-date" title="{{formatDateFull created_at}}">{{formatDate created_at}}</span></li>
            {{/if}}

            {{#if isDetail}}
                {{#if user}}
                    <li>
                        {{#if isFavorited}}
                        <a href="/post/unfavorite/{{id}}">unfavourite</a>
                        {{else}}
                        <a href="/post/favorite/{{id}}">favourite</a>
                        {{/if}}
                    </li>

                    {{#if (and isDetail is_job (eq user.id user_id))}}
                    <li>
                        <a href="/job/item/{{id}}/remove">remove offer</a>
                    </li>
                    {{/if}}
                    {{#if (and isDetail (not is_job) (not is_promoted) (eq user.id user_id))}}
                    <li>
                        <a href="/post/item/{{id}}/remove" class="confirm-action" data-csrf="{{@root.csrfToken}}">remove</a>
                    </li>
                    {{/if}}
                    {{#if (and isDetail is_promoted (eq user.id user_id))}}
                    <li>
                        <a href="/promoted/item/{{id}}/remove" class="confirm-action" data-csrf="{{@root.csrfToken}}">remove</a>
                    </li>
                    {{/if}}
                {{/if}}
            {{/if}}
        </ul>
    </div>
    
    {{#if description}}
        {{#if isDetail}}
        <div class="post-content">{{{formatTextBlockContent description}}}</div>
        {{/if}}
    {{/if}}
</div>
