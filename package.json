    "build:css": "lessc --clean-css styles/style.less public/style.min.css",
    "build:js": "terser public/js/item.js -o public/js/item.min.js --compress --mangle && terser public/js/schedule.js -o public/js/schedule.min.js --compress --mangle",
    "build": "npm run build:css && npm run build:js"
  },
