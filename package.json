    "express": "^5.1.0",
    "express-handlebars": "^8.0.4",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "less": "^4.4.2",
    "less-middleware": "^3.1.0",
    "mariadb": "^3.4.5",
    "nodemailer": "^7.0.11",
