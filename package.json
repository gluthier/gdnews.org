{
  "name": "gdnews",
  "version": "2.0.0",
  "description": "Static game development news aggregator pipeline",
  "type": "commonjs",
  "scripts": {
    "db:reset": "node src/database/reset_minimal_db.js",
    "crawl": "node src/crawler/index.js",
    "build:css": "lessc --clean-css styles/style.less public/style.min.css",
    "seed:fake": "node scripts/seed-fake-posts.js",
    "build:static": "node src/static/build-site.js",
    "build": "npm run build:css && npm run build:static",
    "refresh": "npm run build:css && node src/pipeline/refresh.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "less": "^4.4.2",
    "mariadb": "^3.4.5",
    "node-llama-cpp": "^3.14.5",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "jest": "^30.2.0"
  }
}
